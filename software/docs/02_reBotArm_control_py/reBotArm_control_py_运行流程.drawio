                <mxCell id="t-ik-check" value="IK 收敛？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12" parent="1" vertex="1">
                    <mxGeometry x="245" y="440" width="130" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="t-ik-fail" value="报错退出&#xa;IK 未收敛" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="430" y="445" width="110" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="t-fk" value="③ 正运动学 FK（算起终点的 SE(3) 变换矩阵）&#xa;T_start = compute_fk(q_start)&#xa;T_end = compute_fk(q_end)&#xa;─────────────────────────&#xa;📂 kinematics/forward_kinematics.py → compute_fk()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="110" y="540" width="400" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="t-geodesic" value="④ SE(3) 测地线轨迹规划&#xa;plan_cartesian_geodesic_trajectory(T_start, T_end, duration)&#xa;输出：N 个笛卡尔轨迹点 [CartesianPoint, ...]&#xa;（末端沿直线匀速/min-jerk 走过去）&#xa;─────────────────────────&#xa;📂 trajectory/sampler.py → plan_cartesian_geodesic_trajectory()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="110" y="650" width="400" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="t-clik" value="⑤ CLIK 逆运动学跟踪&#xa;track_trajectory(笛卡尔轨迹, q_start)&#xa;每个笛卡尔点做一次 IK → 关节角度序列&#xa;输出：[JointTrajectoryPoint(q, t), ...]&#xa;─────────────────────────&#xa;📂 trajectory/clik_tracker.py → track_trajectory()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="110" y="780" width="400" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="t-send" value="⑥ 轨迹发送线程 _send_loop()&#xa;按时间间隔逐点更新 _q_target&#xa;interval = duration / N&#xa;─────────────────────────&#xa;📂 controllers/arm_endpos_controller.py → ArmEndPos._send_loop()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" parent="1" vertex="1">
